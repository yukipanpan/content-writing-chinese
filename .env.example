# ── LLM configuration ────────────────────────────────────────────────────────
#
# This system works with any OpenAI-compatible endpoint.
# Set these three variables to point at your preferred model:
#
#   LLM_BASE_URL   Base URL of the API endpoint
#   LLM_MODEL      Model name (provider-specific)
#   LLM_API_KEY    API key (use any non-empty string for keyless local endpoints)
#
# ── Provider examples ─────────────────────────────────────────────────────────

# OpenAI
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-...

# Groq — fast inference, generous free tier (https://console.groq.com)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.1-8b-instant
# LLM_API_KEY=gsk_...

# Mistral
# LLM_BASE_URL=https://api.mistral.ai/v1
# LLM_MODEL=mistral-small-latest
# LLM_API_KEY=...

# Together AI
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
# LLM_API_KEY=...

# Ollama — local, no key needed (https://ollama.com)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama

# LM Studio — local (https://lmstudio.ai)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model
# LLM_API_KEY=lm-studio

# Company / internal gateway — any OpenAI-compatible endpoint works
# LLM_BASE_URL=http://your-llm-gateway/v1
# LLM_MODEL=your-model-name
# LLM_API_KEY=your-internal-key

# ── Claude Code — no API key needed ──────────────────────────────────────────
# If you have Claude Code installed, skip all of the above and use:
# LLM_PROVIDER=claude-code
